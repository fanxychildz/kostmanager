# Copy to .env and adjust. All values have sensible defaults for local dev.

# --- Auth (better-auth) ---
# REQUIRED in production. Generate one: openssl rand -hex 32
BETTER_AUTH_SECRET=kostmanager-dev-secret-change-me-in-production
# Public base URL — used for cookies and trusted origins.
BETTER_AUTH_URL=http://localhost:3000

# --- Database (SQLite via Drizzle) ---
# Path to the SQLite file. Docker sets this to /app/data/kostmanager.db (volume).
DATABASE_PATH=kostmanager.db

# --- Production server (server.mjs) ---
PORT=3000
HOST=0.0.0.0

# --- Seeding ---
# When "true", the Docker entrypoint seeds idempotent demo data on boot.
SEED=false

# --- Google OAuth Credentials ---
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

